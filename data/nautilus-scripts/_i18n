#!/bin/bash
# _i18n - shell i18n helper for PKGBUILD Manager
# Source this at the top of every script:
#   source "$(dirname "$0")/_i18n"

# ---------------------------------------------------------------------------
# Detect locale
# ---------------------------------------------------------------------------
_LANG="${LANGUAGE:-${LC_ALL:-${LC_MESSAGES:-${LANG:-en}}}}"
_LANG="${_LANG%%:*}"
_LANG="${_LANG%%.*}"
_LANG_SHORT="${_LANG%%_*}"

# ---------------------------------------------------------------------------
# Locate .po file
# ---------------------------------------------------------------------------
_SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

_find_po() {
    local lang="$1"
    local f
    f="/usr/share/pkgbuild-manager/i18n/${lang}.po"
    [[ -f "$f" ]] && { echo "$f"; return; }
    f="${_SCRIPTS_DIR}/../../po/${lang}.po"
    f="$(cd "$(dirname "$f")" 2>/dev/null && pwd)/$(basename "$f")"
    [[ -f "$f" ]] && { echo "$f"; return; }
    echo ""
}

_PO_FILE="$(_find_po "$_LANG")"
[[ -z "$_PO_FILE" ]] && _PO_FILE="$(_find_po "$_LANG_SHORT")"

# ---------------------------------------------------------------------------
# Parse msgid from .po using grep+sed (no awk single-quote nesting)
# ---------------------------------------------------------------------------
_getmsg() {
    local msgid="$1"
    local po="$2"
    if [[ -z "$po" || ! -f "$po" ]]; then
        _en_fallback "$msgid"
        return
    fi
    # Find line number of: msgid "<msgid>"
    local line_no
    line_no=$(grep -n "^msgid \"${msgid}\"" "$po" | head -1 | cut -d: -f1)
    if [[ -z "$line_no" ]]; then
        _en_fallback "$msgid"
        return
    fi
    # Get the msgstr on the next line after that msgid
    local next_line=$(( line_no + 1 ))
    local raw
    raw=$(sed -n "${next_line}p" "$po")
    # Extract content between the first pair of double quotes after msgstr
    if [[ "$raw" =~ ^msgstr[[:space:]]+\"(.*)\"$ ]]; then
        local val="${BASH_REMATCH[1]}"
        if [[ -n "$val" ]]; then
            printf '%b' "${val//\\\"/\"}"
            return
        fi
    fi
    _en_fallback "$msgid"
}

# ---------------------------------------------------------------------------
# English fallbacks
# ---------------------------------------------------------------------------
_en_fallback() {
    case "$1" in
        # Build
        notify_building)              echo "Building package..." ;;
        notify_build_ok)              echo "Build completed successfully!" ;;
        notify_build_fail)            echo "Build failed! See: " ;;
        notify_build_force)           echo "Force-building package..." ;;
        notify_build_force_ok)        echo "Force build completed!" ;;
        notify_build_force_fail)      echo "Force build failed! See: " ;;
        notify_build_nocheck)         echo "Building (skipping checks)..." ;;
        notify_build_nocheck_ok)      echo "Build (no check) completed!" ;;
        notify_build_nocheck_fail)    echo "Build (no check) failed! See: " ;;
        notify_build_nogpg)           echo "Building (skipping GPG)..." ;;
        notify_build_nogpg_ok)        echo "Build (no GPG) completed!" ;;
        notify_build_nogpg_fail)      echo "Build (no GPG) failed! See: " ;;
        notify_fetch_sources)         echo "Fetching sources..." ;;
        notify_fetch_sources_ok)      echo "Sources fetched successfully!" ;;
        notify_fetch_sources_fail)    echo "Failed to fetch sources! See: " ;;
        # Install
        notify_installing)            echo "Installing package..." ;;
        notify_install_ok)            echo "Install completed!" ;;
        notify_install_fail)          echo "Install failed! See: " ;;
        notify_install_force)         echo "Force-installing package..." ;;
        notify_install_force_ok)      echo "Force install completed!" ;;
        notify_install_force_fail)    echo "Force install failed! See: " ;;
        notify_install_rmdeps)        echo "Installing (removing build deps)..." ;;
        notify_install_rmdeps_ok)     echo "Install (rmdeps) completed!" ;;
        notify_install_rmdeps_fail)   echo "Install (rmdeps) failed! See: " ;;
        notify_install_nocheck)       echo "Installing (skipping checks)..." ;;
        notify_install_nocheck_ok)    echo "Install (no check) completed!" ;;
        notify_install_nocheck_fail)  echo "Install (no check) failed! See: " ;;
        notify_install_nogpg)         echo "Installing (skipping GPG)..." ;;
        notify_install_nogpg_ok)      echo "Install (no GPG) completed!" ;;
        notify_install_nogpg_fail)    echo "Install (no GPG) failed! See: " ;;
        # Metadata
        notify_checksums)             echo "Updating checksums..." ;;
        notify_checksums_ok)          echo "Checksums updated successfully!" ;;
        notify_checksums_fail)        echo "Failed to update checksums! See: " ;;
        notify_genchecksums)          echo "Generating checksums..." ;;
        notify_genchecksums_ok)       echo "Checksums generated successfully!" ;;
        notify_genchecksums_fail)     echo "Failed to generate checksums! See: " ;;
        notify_srcinfo)               echo "Updating .SRCINFO..." ;;
        notify_srcinfo_ok)            echo ".SRCINFO updated successfully!" ;;
        notify_srcinfo_fail)          echo "Failed to update .SRCINFO! See: " ;;
        # Audit
        notify_namcap)                echo "Running namcap..." ;;
        notify_namcap_warn)           echo "Namcap finished with warnings. See: " ;;
        notify_namcap_ok)             echo "Namcap completed! No warnings found." ;;
        notify_namcap_fail)           echo "Namcap failed! See: " ;;
        notify_shellcheck)            echo "Running ShellCheck..." ;;
        notify_shellcheck_warn)       echo "ShellCheck found warnings. See: " ;;
        notify_shellcheck_ok)         echo "ShellCheck: no issues found." ;;
        notify_shellcheck_fail)       echo "ShellCheck failed! See: " ;;
        # Git / AUR
        notify_push_aur)              echo "Pushing to AUR..." ;;
        notify_push_aur_ok)           echo "Pushed to AUR successfully!" ;;
        notify_push_aur_fail)         echo "Failed to push to AUR! See: " ;;
        notify_push_aur_tag)          echo "Tagging and pushing to AUR..." ;;
        notify_push_aur_tag_ok)       echo "Tagged and pushed to AUR!" ;;
        notify_push_aur_tag_fail)     echo "Failed to tag/push to AUR! See: " ;;
        # Clean
        notify_clean_src)             echo "Cleaning srcdir..." ;;
        notify_clean_src_ok)          echo "srcdir cleaned successfully!" ;;
        notify_clean_src_fail)        echo "Failed to clean srcdir! See: " ;;
        notify_clean_all)             echo "Cleaning everything..." ;;
        notify_clean_all_ok)          echo "Everything cleaned successfully!" ;;
        notify_clean_all_fail)        echo "Failed to clean! See: " ;;
        # Full workflow
        notify_full_workflow)         echo "Running full workflow..." ;;
        notify_full_workflow_ok)      echo "Full workflow completed!" ;;
        notify_full_workflow_fail)    echo "Full workflow failed! See: " ;;
        *)                            echo "$1" ;;
    esac
}

