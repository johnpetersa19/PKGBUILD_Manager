#!/bin/bash
# _i18n - shell i18n helper for PKGBUILD Manager
# Source this at the top of every script:
#   source "$(dirname "$0")/_i18n"

# ---------------------------------------------------------------------------
# Detect locale
# ---------------------------------------------------------------------------
_LANG="${LANGUAGE:-${LC_ALL:-${LC_MESSAGES:-${LANG:-en}}}}"
_LANG="${_LANG%%:*}"
_LANG="${_LANG%%.*}"
_LANG_SHORT="${_LANG%%_*}"

# ---------------------------------------------------------------------------
# Locate .po file
# ---------------------------------------------------------------------------
_SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

_find_po() {
    local lang="$1"
    local f
    f="/usr/share/pkgbuild-manager/i18n/${lang}.po"
    [[ -f "$f" ]] && { echo "$f"; return; }
    f="${_SCRIPTS_DIR}/../../po/${lang}.po"
    f="$(cd "$(dirname "$f")" 2>/dev/null && pwd)/$(basename "$f")"
    [[ -f "$f" ]] && { echo "$f"; return; }
    echo ""
}

_PO_FILE="$(_find_po "$_LANG")"
[[ -z "$_PO_FILE" ]] && _PO_FILE="$(_find_po "$_LANG_SHORT")"

# ---------------------------------------------------------------------------
# OPTIMIZED: Parse entire .po file ONCE into an associative array.
# Previous implementation called grep+sed for every single msgid (~70 calls).
# Now we do a single sequential read of the file — ~70x less I/O.
# Also fixes:
#   - multiline msgstr support (concatenates continuation lines)
#   - grep metacharacter safety (not needed anymore since we use pure bash read)
# ---------------------------------------------------------------------------
declare -A _I18N_CACHE

_load_po() {
    local po="$1"
    [[ -z "$po" || ! -f "$po" ]] && return

    local current_key=""
    local current_val=""
    local in_msgstr=0

    while IFS= read -r line || [[ -n "$line" ]]; do
        # Blank line or comment resets state machine
        if [[ -z "$line" || "$line" == \#* ]]; then
            if [[ -n "$current_key" && -n "$current_val" ]]; then
                _I18N_CACHE["$current_key"]="$current_val"
            fi
            current_key=""
            current_val=""
            in_msgstr=0
            continue
        fi

        if [[ "$line" =~ ^msgid[[:space:]]+\"(.*)\"\ *$ ]]; then
            # Save previous entry if any
            if [[ -n "$current_key" && -n "$current_val" ]]; then
                _I18N_CACHE["$current_key"]="$current_val"
            fi
            current_key="${BASH_REMATCH[1]}"
            current_val=""
            in_msgstr=0
        elif [[ "$line" =~ ^msgstr[[:space:]]+\"(.*)\"\ *$ ]]; then
            current_val="${BASH_REMATCH[1]}"
            in_msgstr=1
        elif [[ $in_msgstr -eq 1 && "$line" =~ ^\"(.*)\"\ *$ ]]; then
            # Multiline msgstr continuation
            current_val+="${BASH_REMATCH[1]}"
        fi
    done < "$po"

    # Flush last entry
    if [[ -n "$current_key" && -n "$current_val" ]]; then
        _I18N_CACHE["$current_key"]="$current_val"
    fi
}

_load_po "$_PO_FILE"

# ---------------------------------------------------------------------------
# Lookup a msgid from cache, fallback to English hardcoded strings
# ---------------------------------------------------------------------------
_getmsg() {
    local msgid="$1"
    local val="${_I18N_CACHE[$msgid]:-}"
    if [[ -n "$val" ]]; then
        printf '%b' "${val//\\\"/\"}"
    else
        _en_fallback "$msgid"
    fi
}

# ---------------------------------------------------------------------------
# English fallbacks
# ---------------------------------------------------------------------------
_en_fallback() {
    case "$1" in
        # Build
        notify_building)              echo "Compiling package…" ;;
        notify_build_ok)              echo "✓ Package compiled successfully!" ;;
        notify_build_fail)            echo "✗ Package compilation failed! View:" ;;
        notify_build_force)           echo "Compilation in progress…" ;;
        notify_build_force_ok)        echo "✓ Compilation completed!" ;;
        notify_build_force_fail)      echo "✗ Compilation based on data failed! View:" ;;
        notify_build_nocheck)         echo "Compiling without checks…" ;;
        notify_build_nocheck_ok)      echo "✓ Compiled without checks!" ;;
        notify_build_nocheck_fail)    echo "✗ Compilation without checks failed! View:" ;;
        notify_build_nogpg)           echo "Compiling without GPG…" ;;
        notify_build_nogpg_ok)        echo "✓ Compiled without GPG!" ;;
        notify_build_nogpg_fail)      echo "✗ Compilation without GPG failed! View:" ;;
        notify_fetch_sources)         echo "Downloading sources…" ;;
        notify_fetch_sources_ok)      echo "✓ Sources downloaded successfully!" ;;
        notify_fetch_sources_fail)    echo "✗ Sources downloaded failed! View:" ;;
        # Install
        notify_installing)            echo "Installing package…" ;;
        notify_install_ok)            echo "✓ Package installed successfully!" ;;
        notify_install_fail)          echo "✗ Package installation failed! View:" ;;
        notify_install_force)         echo "Planned installation in progress…" ;;
        notify_install_force_ok)      echo "✓ Installation completed!" ;;
        notify_install_force_fail)    echo "✗ Forced installation failed! View:" ;;
        notify_install_rmdeps)        echo "Installing and removing compilation dependencies…" ;;
        notify_install_rmdeps_ok)     echo "✓ Installed and compilation dependencies removed!" ;;
        notify_install_rmdeps_fail)   echo "✗ Failed to install and remove build dependencies! See:" ;;
        notify_install_nocheck)       echo "Installing without checks…" ;;
        notify_install_nocheck_ok)    echo "✓ Installed without checks!" ;;
        notify_install_nocheck_fail)  echo "✗ Installation failed without checks! See:" ;;
        notify_install_nogpg)         echo "Installing without GPG…" ;;
        notify_install_nogpg_ok)      echo "✓ Installed without GPG!" ;;
        notify_install_nogpg_fail)    echo "✗ Installation failed without GPG! See:" ;;
        # Metadata
        notify_checksums)             echo "Updating checksums…" ;;
        notify_checksums_ok)          echo "✓ Checksums updated successfully!" ;;
        notify_checksums_fail)        echo "✗ Failed to update checksums! See:" ;;
        notify_genchecksums)          echo "Generating checksums…" ;;
        notify_genchecksums_ok)       echo "✓ Checksums generated successfully!" ;;
        notify_genchecksums_fail)     echo "✗ Failed to generate checksums! See:" ;;
        notify_srcinfo)               echo "Regenerating .SRCINFO…" ;;
        notify_srcinfo_ok)            echo "✓ .SRCINFO regenerated successfully!" ;;
        notify_srcinfo_fail)          echo "✗ Failed to regenerate .SRCINFO! See:" ;;
        # Audit
        notify_namcap)                echo "Running namcap…" ;;
        notify_namcap_warn)           echo "⚠ Namcap encountered warnings. See:" ;;
        notify_namcap_ok)             echo "✓ Namcap: no problems found!" ;;
        notify_namcap_fail)           echo "✗ Failed to execute namcap! See:" ;;
        notify_shellcheck)            echo "Running ShellCheck…" ;;
        notify_shellcheck_warn)       echo "⚠ ShellCheck encountered warnings. See:" ;;
        notify_shellcheck_ok)         echo "✓ ShellCheck: no problems found!" ;;
        notify_shellcheck_fail)       echo "✗ Failed to execute ShellCheck! See:" ;;
        # Git / AUR
        notify_push_aur)              echo "Sending to AUR…" ;;
        notify_push_aur_ok)           echo "✓ Sent to AUR successfully!" ;;
        notify_push_aur_fail)         echo "✗ Failed to send to AUR! See:" ;;
        notify_push_aur_tag)          echo "Creating tag and sending to AUR…" ;;
        notify_push_aur_tag_ok)       echo "✓ Tag created and sent to AUR!" ;;
        notify_push_aur_tag_fail)     echo "✗ Failed to create tag/send to AUR! See:" ;;
        # Clean
        notify_clean_src)             echo "Cleaning srcdir…" ;;
        notify_clean_src_ok)          echo "✓ srcdir cleaned successfully!" ;;
        notify_clean_src_fail)        echo "✗ Failed to clean srcdir! See:" ;;
        notify_clean_all)             echo "Cleaning everything…" ;;
        notify_clean_all_ok)          echo "✓ Everything cleaned successfully!" ;;
        notify_clean_all_fail)        echo "✗ Failed to clean everything! See:" ;;
        # Full workflow
        notify_full_workflow)         echo "Executing complete flow…" ;;
        notify_full_workflow_ok)      echo "✓ Complete flow completed successfully!" ;;
        notify_full_workflow_fail)    echo "✗ Complete flow failed! See:" ;;
        *)                            echo "$1" ;;
    esac
}

