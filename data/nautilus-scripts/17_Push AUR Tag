#!/usr/bin/env bash
# 17_Push AUR Tag — Create an annotated version tag and push commits + tags.
# detect_service() + $SERVICE + $REMOTE_URL are provided by _i18n.
# Opens pkgbuild-manager-aur-push with --tag so the user can type the
# version before confirming.
set -euo pipefail

TARGET="${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}"
TARGET="${TARGET%%$'\n'*}"

# If nothing was selected, use the current working directory.
if [ -z "$TARGET" ]; then
  TARGET="$PWD"
fi

# If a file was selected, use its directory; if a dir was selected, use it directly.
if [ -f "$TARGET" ]; then
  TARGET="$(dirname "$TARGET")"
fi

# _i18n resolves $REMOTE_URL and exports $SERVICE using $TARGET set above.
# $TARGET must be defined before this source line.
source "$(dirname "$0")/_i18n"

# Launch GUI — setsid detaches the process from Nautilus so it gets its own
# D-Bus/Wayland context and is not killed when this script exits.
setsid pkgbuild-manager-aur-push "$TARGET" --tag &
disown
