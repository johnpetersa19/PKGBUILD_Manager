#!/usr/bin/env bash
# 17_Push AUR Tag — Create an annotated version tag and push commits + tags.
# Opens the unified GUI in push mode with --tag so the user
# can type the version before confirming.
set -euo pipefail

TARGET="${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}"
TARGET="${TARGET%%$'\n'*}"

# If nothing was selected, use the current working directory.
if [ -z "$TARGET" ]; then
  TARGET="$PWD"
fi

# If a file was selected, use its directory; if a dir was selected, use it directly.
if [ -f "$TARGET" ]; then
  TARGET="$(dirname "$TARGET")"
fi

# setsid detaches the GUI process from the Nautilus process group so it gets
# its own D-Bus/Wayland context and is not killed when the script exits.
setsid pkgbuild-manager-gui push "$TARGET" --tag &
disown
