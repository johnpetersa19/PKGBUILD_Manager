#!/usr/bin/env bash
# 17_Push AUR Tag — Create an annotated version tag and push commits + tags.
# Opens the same pkgbuild-manager-aur-push GUI with --tag flag so the user
# can type the version before confirming.
set -euo pipefail

TARGET="${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS%%$'\n'*}"
if [ -f "$TARGET" ]; then
  TARGET="$(dirname "$TARGET")"
fi

exec pkgbuild-manager-aur-push "$TARGET" --tag
