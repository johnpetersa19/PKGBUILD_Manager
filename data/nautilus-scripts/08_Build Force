#!/bin/bash
# PKGBUILD Manager - Build Force
TARGET="$(dirname "$(realpath "${1:-.}")")" 
source "$(dirname "$0")/_i18n"
notify-send "PKGBUILD Manager" "$MSG_BUILD_FORCE"

LOG_PATH="${TARGET}/build-force.log"

if pkgbuild_manager build-force "$TARGET" > "$LOG_PATH" 2>&1; then
    rm -f "$LOG_PATH"
    notify-send "PKGBUILD Manager" "$MSG_BUILD_FORCE_OK"
else
    notify-send -u critical "PKGBUILD Manager" "${MSG_BUILD_FORCE_FAIL}$(basename "$LOG_PATH")"
fi
