#!/bin/bash
# PKGBUILD Manager - Clean Everything
# Removes src/, pkg/, built packages, bare-repo caches and _build* dirs.
# Handles read-only trees (git object files at 444/555) via remove_dir_force
# in the Rust backend — no manual chmod needed from this script.
set -euo pipefail

TARGET="${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}"
TARGET="${TARGET%%$'\n'*}"
if [ -z "$TARGET" ]; then TARGET="$PWD"; fi
if [ -f "$TARGET" ]; then TARGET="$(dirname "$TARGET")"; fi

source "$(dirname "$0")/_i18n"

# The GUI scans first and keeps the destructive action locked until the user
# reviews the candidates and explicitly enables the authorization switch.
pkgbuild-manager-gui clean "$TARGET"
