#!/bin/bash
# PKGBUILD Manager - Clean Everything
set -euo pipefail

TARGET="${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}"
TARGET="${TARGET%%$'\n'*}"
if [ -z "$TARGET" ]; then TARGET="$PWD"; fi
if [ -f "$TARGET" ]; then TARGET="$(dirname "$TARGET")"; fi

source "$(dirname "$0")/_i18n"
notify-send "PKGBUILD Manager" "$MSG_CLEAN_ALL"

# Use a temp file outside TARGET so the log is never inside the dir being cleaned.
LOG_PATH="$(mktemp /tmp/pkgbuild-clean-all-XXXXXX.log)"

if pkgbuild_manager clean-all "$TARGET" > "$LOG_PATH" 2>&1; then
    rm -f "$LOG_PATH"
    notify-send "PKGBUILD Manager" "$MSG_CLEAN_ALL_OK"
else
    notify-send -u critical "PKGBUILD Manager" "${MSG_CLEAN_ALL_FAIL}${LOG_PATH}"
fi
