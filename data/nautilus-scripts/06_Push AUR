#!/usr/bin/env bash
# 06_Push AUR — Stage PKGBUILD/.SRCINFO, commit (upgpkg: …) and push to AUR.
# Runs the full logic via pkgbuild_manager aur-push, streaming progress to the
# dedicated gtk4-rs/libadwaita GUI window (pkgbuild-manager-aur-push).
set -euo pipefail

TARGET="${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS%%$'\n'*}"
# If a file was selected, use its directory; if a dir was selected, use it directly.
if [ -f "$TARGET" ]; then
  TARGET="$(dirname "$TARGET")"
fi

exec pkgbuild-manager-aur-push "$TARGET"
