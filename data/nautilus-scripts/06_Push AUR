#!/usr/bin/env bash
# 06_Push AUR — Stage PKGBUILD/.SRCINFO, commit (upgpkg: …) and push.
# Detects the git remote host and exports SERVICE= so the GUI can show
# e.g. "Enviar para GitHub" / "Send to GitHub" dynamically.
set -euo pipefail

TARGET="${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}"
TARGET="${TARGET%%$'\n'*}"

# If nothing was selected, use the current working directory.
if [ -z "$TARGET" ]; then
  TARGET="$PWD"
fi

# If a file was selected, use its directory; if a dir was selected, use it directly.
if [ -f "$TARGET" ]; then
  TARGET="$(dirname "$TARGET")"
fi

# ── Detect remote host ────────────────────────────────────────────────────────
# Read the 'origin' remote URL; fall back to the first remote if origin absent.
REMOTE_URL=""
if git -C "$TARGET" remote get-url origin &>/dev/null; then
  REMOTE_URL="$(git -C "$TARGET" remote get-url origin 2>/dev/null || true)"
elif git -C "$TARGET" remote &>/dev/null; then
  FIRST_REMOTE="$(git -C "$TARGET" remote | head -n1)"
  REMOTE_URL="$(git -C "$TARGET" remote get-url "$FIRST_REMOTE" 2>/dev/null || true)"
fi

# Map URL to a human-readable service name used by the GUI.
detect_service() {
  local url="$1"
  case "$url" in
    *aur.archlinux.org*)     echo "AUR"       ;;
    *github.com*)            echo "GitHub"    ;;
    *gitlab.com*)            echo "GitLab"    ;;
    *codeberg.org*)          echo "Codeberg"  ;;
    *gitea.*)                echo "Gitea"     ;;
    *bitbucket.org*)         echo "Bitbucket" ;;
    *sourcehut.org*|*sr.ht*) echo "SourceHut" ;;
    *)                       echo "AUR"       ;;
  esac
}

export SERVICE="$(detect_service "$REMOTE_URL")"
export REMOTE_URL

# ── Launch GUI ────────────────────────────────────────────────────────────────
# setsid detaches the GUI process from the Nautilus process group so it gets
# its own D-Bus/Wayland context and is not killed when the script exits.
setsid pkgbuild-manager-aur-push "$TARGET" &
disown
