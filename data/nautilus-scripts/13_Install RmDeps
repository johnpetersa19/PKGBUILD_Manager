#!/bin/bash
# PKGBUILD Manager - Install RmDeps
set -euo pipefail

TARGET="${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}"
TARGET="${TARGET%%$'\n'*}"
if [ -z "$TARGET" ]; then TARGET="$PWD"; fi
if [ -f "$TARGET" ]; then TARGET="$(dirname "$TARGET")"; fi

source "$(dirname "$0")/_i18n"
notify-send "PKGBUILD Manager" "$MSG_INSTALL_RMDEPS"

LOG_PATH="${TARGET}/install-rmdeps.log"

if pkgbuild_manager install-rmdeps "$TARGET" > "$LOG_PATH" 2>&1; then
    rm -f "$LOG_PATH"
    notify-send "PKGBUILD Manager" "$MSG_INSTALL_RMDEPS_OK"
else
    notify-send -u critical "PKGBUILD Manager" "${MSG_INSTALL_RMDEPS_FAIL}$(basename "$LOG_PATH")"
fi
