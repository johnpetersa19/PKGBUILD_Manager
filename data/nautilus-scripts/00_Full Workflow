#!/usr/bin/env bash
# PKGBUILD Manager - Full Workflow
# Bug #2 fix: resolve TARGET from NAUTILUS_SCRIPT_SELECTED_FILE_PATHS
# (same pattern as 06_Push AUR). The old `dirname "$(realpath "${1:-.}")"` form
# stripped the last path component of a directory, sending the command to the
# PARENT of the selected folder instead of the folder itself.
set -euo pipefail

TARGET="${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}"
TARGET="${TARGET%%$'\n'*}"
if [ -z "$TARGET" ]; then TARGET="$PWD"; fi
if [ -f "$TARGET" ]; then TARGET="$(dirname "$TARGET")"; fi

# shellcheck source=_i18n
source "$(dirname "$0")/_i18n"
# shellcheck source=_run_in_terminal
source "$(dirname "$0")/_run_in_terminal"

notify-send "PKGBUILD Manager" "$MSG_FULL_WORKFLOW"
run_in_terminal "pkgbuild_manager install $(printf '%q' "$TARGET")"
