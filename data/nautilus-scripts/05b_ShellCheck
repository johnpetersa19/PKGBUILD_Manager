#!/bin/bash
# PKGBUILD Manager - ShellCheck (lint PKGBUILD)
TARGET="${1:-.}"
notify-send "PKGBUILD Manager" "Running ShellCheck..."

LOG_PATH="${TARGET}/shellcheck.log"

if pkgbuild_manager shellcheck "$TARGET" > "$LOG_PATH" 2>&1; then
    if [ -s "$LOG_PATH" ]; then
        notify-send "PKGBUILD Manager" "⚠ ShellCheck found warnings. See: $(basename "$LOG_PATH")"
    else
        rm -f "$LOG_PATH"
        notify-send "PKGBUILD Manager" "✓ ShellCheck completed! Code is clean."
    fi
else
    if [ -s "$LOG_PATH" ]; then
        notify-send -u critical "PKGBUILD Manager" "✗ ShellCheck found errors! See: $(basename "$LOG_PATH")"
    else
        notify-send -u critical "PKGBUILD Manager" "✗ Failed to run ShellCheck."
        rm -f "$LOG_PATH"
    fi
fi
