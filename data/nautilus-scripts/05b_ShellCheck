#!/bin/bash
# PKGBUILD Manager - ShellCheck
set -euo pipefail

TARGET="${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}"
TARGET="${TARGET%%$'\n'*}"
if [ -z "$TARGET" ]; then TARGET="$PWD"; fi
if [ -f "$TARGET" ]; then TARGET="$(dirname "$TARGET")"; fi

source "$(dirname "$0")/_i18n"
notify-send "PKGBUILD Manager" "$MSG_SHELLCHECK"

LOG_PATH="${TARGET}/shellcheck.log"

if pkgbuild_manager shellcheck "$TARGET" > "$LOG_PATH" 2>&1; then
    if [[ -s "$LOG_PATH" ]]; then
        notify-send -u normal "PKGBUILD Manager" "${MSG_SHELLCHECK_WARN}$(basename "$LOG_PATH")"
    else
        rm -f "$LOG_PATH"
        notify-send "PKGBUILD Manager" "$MSG_SHELLCHECK_OK"
    fi
else
    notify-send -u critical "PKGBUILD Manager" "${MSG_SHELLCHECK_FAIL}$(basename "$LOG_PATH")"
fi
