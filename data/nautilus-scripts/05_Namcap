#!/bin/bash
# PKGBUILD Manager - Namcap
set -euo pipefail

TARGET="${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}"
TARGET="${TARGET%%$'\n'*}"
if [ -z "$TARGET" ]; then TARGET="$PWD"; fi
if [ -f "$TARGET" ]; then TARGET="$(dirname "$TARGET")"; fi

source "$(dirname "$0")/_i18n"
notify-send "PKGBUILD Manager" "$MSG_NAMCAP"

LOG_PATH="${TARGET}/namcap.log"

if pkgbuild_manager namcap "$TARGET" > "$LOG_PATH" 2>&1; then
    if grep -q 'W:' "$LOG_PATH"; then
        notify-send -u normal "PKGBUILD Manager" "${MSG_NAMCAP_WARN}$(basename "$LOG_PATH")"
    else
        rm -f "$LOG_PATH"
        notify-send "PKGBUILD Manager" "$MSG_NAMCAP_OK"
    fi
else
    notify-send -u critical "PKGBUILD Manager" "${MSG_NAMCAP_FAIL}$(basename "$LOG_PATH")"
fi
