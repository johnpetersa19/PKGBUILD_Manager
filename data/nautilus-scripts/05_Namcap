#!/bin/bash
# PKGBUILD Manager - Namcap audit
TARGET="${1:-.}"
notify-send "PKGBUILD Manager" "Running namcap..."

LOG_PATH="${TARGET}/namcap.log"

if pkgbuild_manager namcap "$TARGET" > "$LOG_PATH" 2>&1; then
    if [ -s "$LOG_PATH" ]; then
        notify-send "PKGBUILD Manager" "⚠ Namcap finished with warnings. See: $(basename "$LOG_PATH")"
    else
        rm -f "$LOG_PATH"
        notify-send "PKGBUILD Manager" "✓ Namcap completed! No warnings found."
    fi
else
    notify-send -u critical "PKGBUILD Manager" "✗ Namcap failed! See: $(basename "$LOG_PATH")"
fi
