#!/bin/bash
# PKGBUILD Manager - Fetch Sources
set -euo pipefail

TARGET="${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}"
TARGET="${TARGET%%$'\n'*}"
if [ -z "$TARGET" ]; then TARGET="$PWD"; fi
if [ -f "$TARGET" ]; then TARGET="$(dirname "$TARGET")"; fi

source "$(dirname "$0")/_i18n"
notify-send "PKGBUILD Manager" "$MSG_FETCH_SOURCES"

LOG_PATH="${TARGET}/fetch-sources.log"

if pkgbuild_manager fetch-sources "$TARGET" > "$LOG_PATH" 2>&1; then
    rm -f "$LOG_PATH"
    notify-send "PKGBUILD Manager" "$MSG_FETCH_SOURCES_OK"
else
    notify-send -u critical "PKGBUILD Manager" "${MSG_FETCH_SOURCES_FAIL}$(basename "$LOG_PATH")"
fi
