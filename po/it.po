# CLI strings
msgid "Failed to resolve parent directory"
msgstr "Impossibile risolvere la directory padre"

msgid "Directory does not exist"
msgstr "La directory non esiste"

msgid "No PKGBUILD found in directory"
msgstr "Nessun PKGBUILD trovato nella directory"

msgid "Failed to read PKGBUILD info with makepkg --printsrcinfo"
msgstr "Impossibile leggere le informazioni PKGBUILD con makepkg --printsrcinfo"

msgid "aur-push-tag requires a version tag argument"
msgstr "aur-push-tag richiede un argomento di tag di versione"

msgid "Unknown command"
msgstr "Comando sconosciuto"

msgid "PKGBUILD Manager - CLI Tool"
msgstr "Gestore PKGBUILD - Strumento CLI"

msgid "Usage:"
msgstr "Utilizzo:"

msgid "Build commands"
msgstr "Comandi di compilazione"

msgid "Compile package (makepkg)"
msgstr "Compilare il pacchetto (makepkg)"

msgid "Compile and clean srcdir (makepkg -c)"
msgstr "Compilare e pulire srcdir (makepkg -c)"

msgid "Force recompile (makepkg -f)"
msgstr "Forzare la ricompilazione (makepkg -f)"

msgid "Skip check() function (makepkg --nocheck)"
msgstr "Saltare la funzione check() (makepkg --nocheck)"

msgid "Skip PGP signature check (makepkg --skippgpcheck)"
msgstr "Saltare la verifica della firma PGP (makepkg --skippgpcheck)"

msgid "Compile with custom flags passed after path"
msgstr "Compilare con flag personalizzate passate dopo il percorso"

msgid "Download and extract sources only (makepkg -o)"
msgstr "Solo scaricare ed estrarre le sorgenti (makepkg -o)"

msgid "Install commands"
msgstr "Comandi di installazione"

msgid "Compile, install and resolve deps (makepkg -si)"
msgstr "Compilare, installare e risolvere le dipendenze (makepkg -si)"

msgid "Compile, install and clean srcdir (makepkg -sic)"
msgstr "Compilare, installare e pulire srcdir (makepkg -sic)"

msgid "Force compile and install (makepkg -sif)"
msgstr "Forzare compilazione e installazione (makepkg -sif)"

msgid "Install and remove makedeps after (makepkg -sir)"
msgstr "Installare e rimuovere le dipendenze di build dopo (makepkg -sir)"

msgid "Install without running check()"
msgstr "Installare senza eseguire check()"

msgid "Install skipping PGP checks"
msgstr "Installare saltando le verifiche PGP"

msgid "Install with custom flags passed after path"
msgstr "Installare con flag personalizzate passate dopo il percorso"

msgid "Package metadata commands"
msgstr "Comandi per i metadati del pacchetto"

msgid "Update checksums in PKGBUILD (updpkgsums)"
msgstr "Aggiornare i checksum nel PKGBUILD (updpkgsums)"

msgid "Generate checksums and print to stdout (makepkg -g)"
msgstr "Generare i checksum e stamparli su stdout (makepkg -g)"

msgid "Regenerate .SRCINFO (makepkg --printsrcinfo)"
msgstr "Rigenerare .SRCINFO (makepkg --printsrcinfo)"

msgid "Audit commands"
msgstr "Comandi di audit"

msgid "Run namcap on PKGBUILD and built packages"
msgstr "Eseguire namcap su PKGBUILD e i pacchetti compilati"

msgid "Run shellcheck on PKGBUILD"
msgstr "Eseguire shellcheck su PKGBUILD"

msgid "Clean commands"
msgstr "Comandi di pulizia"

msgid "Clean srcdir with makepkg (makepkg -c)"
msgstr "Pulire srcdir con makepkg (makepkg -c)"

msgid "Remove src/, pkg/ and built packages"
msgstr "Rimuovere src/, pkg/ e i pacchetti compilati"

msgid "AUR/Git commands"
msgstr "Comandi AUR/Git"

msgid "Stage, commit and push to AUR (auto message if not provided)"
msgstr "Preparare, confermare e inviare all'AUR (messaggio automatico se non fornito)"

msgid "Push with version tag (e.g. 1.2.3-1)"
msgstr "Inviare con tag di versione (es: 1.2.3-1)"

msgid "Other"
msgstr "Altro"

msgid "Show this help message"
msgstr "Mostrare questo messaggio di aiuto"

msgid "namcap not found. Install it with: sudo pacman -S namcap"
msgstr "namcap non trovato. Installarlo con: sudo pacman -S namcap"

msgid "namcap failed with status"
msgstr "namcap fallito con stato"

msgid "shellcheck not found. Install it with: sudo pacman -S shellcheck"
msgstr "shellcheck non trovato. Installarlo con: sudo pacman -S shellcheck"

msgid "updpkgsums not found. Install it with: sudo pacman -S pacman-contrib"
msgstr "updpkgsums non trovato. Installarlo con: sudo pacman -S pacman-contrib"

msgid "makepkg -g failed:"
msgstr "makepkg -g fallito:"

msgid "Removing src/ pkg/ and built packages in"
msgstr "Rimozione di src/, pkg/ e dei pacchetti compilati in"

msgid "Removed"
msgstr "Rimosso"

msgid "Note: nothing to commit or commit failed — continuing with push."
msgstr "Nota: nulla da confermare o conferma fallita — continuando con il push."

msgid "makepkg --printsrcinfo failed:"
msgstr "makepkg --printsrcinfo fallito:"

msgid "Note: push to origin/master failed"
msgstr "Nota: push verso origin/master fallito"

msgid "Trying plain 'git push'..."
msgstr "Tentativo di 'git push' semplice..."

msgid "Symlink scripts to user directory with localization"
msgstr "Creare collegamenti simbolici degli script nella directory utente con localizzazione"

msgid "Nautilus scripts successfully configured under 'PKGBUILD' submenu."
msgstr "Script Nautilus configurati con successo nel sottomenu 'PKGBUILD'."
