msgstr "Aggiornamento dei checksum in corso..."

msgid "notify_checksums_ok"
msgstr "✓ Checksum aggiornati con successo!"

msgid "notify_checksums_fail"
msgstr "✗ Errore nell'aggiornamento dei checksum! Vedi: "

