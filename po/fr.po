# CLI strings
msgid "Failed to resolve parent directory"
msgstr "Impossible de r\u00e9soudre le r\u00e9pertoire parent"

msgid "Directory does not exist"
msgstr "Le r\u00e9pertoire n'existe pas"

msgid "No PKGBUILD found in directory"
msgstr "Aucun PKGBUILD trouv\u00e9 dans le r\u00e9pertoire"

msgid "Failed to read PKGBUILD info with makepkg --printsrcinfo"
msgstr "Impossible de lire les informations PKGBUILD avec makepkg --printsrcinfo"

msgid "aur-push-tag requires a version tag argument"
msgstr "aur-push-tag n\u00e9cessite un argument de tag de version"

msgid "Unknown command"
msgstr "Commande inconnue"

msgid "PKGBUILD Manager - CLI Tool"
msgstr "Gestionnaire PKGBUILD - Outil CLI"

msgid "Usage:"
msgstr "Utilisation\u00a0:"

msgid "Build commands"
msgstr "Commandes de compilation"

msgid "Compile package (makepkg)"
msgstr "Compiler le paquet (makepkg)"

msgid "Compile and clean srcdir (makepkg -c)"
msgstr "Compiler et nettoyer srcdir (makepkg -c)"

msgid "Force recompile (makepkg -f)"
msgstr "Forcer la recompilation (makepkg -f)"

msgid "Skip check() function (makepkg --nocheck)"
msgstr "Ignorer la fonction check() (makepkg --nocheck)"

msgid "Skip PGP signature check (makepkg --skippgpcheck)"
msgstr "Ignorer la v\u00e9rification de signature PGP (makepkg --skippgpcheck)"

msgid "Compile with custom flags passed after path"
msgstr "Compiler avec des drapeaux personnalis\u00e9s pass\u00e9s apr\u00e8s le chemin"

msgid "Download and extract sources only (makepkg -o)"
msgstr "T\u00e9l\u00e9charger et extraire les sources uniquement (makepkg -o)"

msgid "Install commands"
msgstr "Commandes d'installation"

msgid "Compile, install and resolve deps (makepkg -si)"
msgstr "Compiler, installer et r\u00e9soudre les d\u00e9pendances (makepkg -si)"

msgid "Compile, install and clean srcdir (makepkg -sic)"
msgstr "Compiler, installer et nettoyer srcdir (makepkg -sic)"

msgid "Force compile and install (makepkg -sif)"
msgstr "Forcer la compilation et l'installation (makepkg -sif)"

msgid "Install and remove makedeps after (makepkg -sir)"
msgstr "Installer et supprimer les makedeps apr\u00e8s (makepkg -sir)"

msgid "Install without running check()"
msgstr "Installer sans ex\u00e9cuter check()"

msgid "Install skipping PGP checks"
msgstr "Installer en ignorant les v\u00e9rifications PGP"

msgid "Install with custom flags passed after path"
msgstr "Installer avec des drapeaux personnalis\u00e9s pass\u00e9s apr\u00e8s le chemin"

msgid "Package metadata commands"
msgstr "Commandes de m\u00e9tadonn\u00e9es du paquet"

msgid "Update checksums in PKGBUILD (updpkgsums)"
msgstr "Mettre \u00e0 jour les checksums dans PKGBUILD (updpkgsums)"

msgid "Generate checksums and print to stdout (makepkg -g)"
msgstr "G\u00e9n\u00e9rer les checksums et afficher sur stdout (makepkg -g)"

msgid "Regenerate .SRCINFO (makepkg --printsrcinfo)"
msgstr "R\u00e9g\u00e9n\u00e9rer .SRCINFO (makepkg --printsrcinfo)"

msgid "Audit commands"
msgstr "Commandes d'audit"

msgid "Run namcap on PKGBUILD and built packages"
msgstr "Ex\u00e9cuter namcap sur PKGBUILD et les paquets compil\u00e9s"

msgid "Run shellcheck on PKGBUILD"
msgstr "Ex\u00e9cuter shellcheck sur PKGBUILD"

msgid "Clean commands"
msgstr "Commandes de nettoyage"

msgid "Clean srcdir with makepkg (makepkg -c)"
msgstr "Nettoyer srcdir avec makepkg (makepkg -c)"

msgid "Remove src/, pkg/ and built packages"
msgstr "Supprimer src/, pkg/ et les paquets compil\u00e9s"

msgid "AUR/Git commands"
msgstr "Commandes AUR/Git"

msgid "Stage, commit and push to AUR (auto message if not provided)"
msgstr "Ajouter, valider et pousser vers l'AUR (message automatique si non fourni)"

msgid "Push with version tag (e.g. 1.2.3-1)"
msgstr "Pousser avec un tag de version (ex\u00a0: 1.2.3-1)"

msgid "Other"
msgstr "Autre"

msgid "Show this help message"
msgstr "Afficher ce message d'aide"

msgid "namcap not found. Install it with: sudo pacman -S namcap"
msgstr "namcap introuvable. Installez-le avec\u00a0: sudo pacman -S namcap"

msgid "namcap failed with status"
msgstr "namcap a \u00e9chou\u00e9 avec le statut"

msgid "shellcheck not found. Install it with: sudo pacman -S shellcheck"
msgstr "shellcheck introuvable. Installez-le avec\u00a0: sudo pacman -S shellcheck"

msgid "updpkgsums not found. Install it with: sudo pacman -S pacman-contrib"
msgstr "updpkgsums introuvable. Installez-le avec\u00a0: sudo pacman -S pacman-contrib"

msgid "makepkg -g failed:"
msgstr "makepkg -g a \u00e9chou\u00e9\u00a0:"

msgid "Removing src/ pkg/ and built packages in"
msgstr "Suppression de src/, pkg/ et des paquets compil\u00e9s dans"

msgid "Removed"
msgstr "Supprim\u00e9"

msgid "Note: nothing to commit or commit failed \u2014 continuing with push."
msgstr "Note\u00a0: rien \u00e0 valider ou \u00e9chec du commit \u2014 poursuite du push."

msgid "makepkg --printsrcinfo failed:"
msgstr "makepkg --printsrcinfo a \u00e9chou\u00e9\u00a0:"

msgid "Note: push to origin/master failed"
msgstr "Note\u00a0: push vers origin/master a \u00e9chou\u00e9"

msgid "Trying plain 'git push'..."
msgstr "Tentative de 'git push' simple..."

msgid "Symlink scripts to user directory with localization"
msgstr "Cr\u00e9er des liens symboliques des scripts dans le r\u00e9pertoire utilisateur avec localisation"

msgid "Nautilus scripts successfully configured under 'PKGBUILD' submenu."
msgstr "Scripts Nautilus configur\u00e9s avec succ\u00e8s dans le sous-menu 'PKGBUILD'."
