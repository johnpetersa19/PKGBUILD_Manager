msgstr "Mettre à jour .SRCINFO"

msgid "05_Namcap"
msgstr "Namcap"

msgid "05b_ShellCheck"
msgstr "ShellCheck"

msgid "06_Push AUR"
msgstr "Envoyer vers l'AUR"

msgid "07_Clean srcdir"
msgstr "Nettoyer srcdir"

msgid "07b_Clean Everything"
msgstr "Tout nettoyer"

