msgstr "Supprimé"

msgid "Note: nothing to commit or commit failed — continuing with push."
msgstr "Note : rien à commiter ou le commit a échoué — poursuite du push."

msgid "makepkg --printsrcinfo failed:"
msgstr "makepkg --printsrcinfo a échoué :"

msgid "Note: push to origin/master failed"
msgstr "Note : échec du push vers origin/master"

msgid "Trying plain 'git push'..."
msgstr "Tentant de push simple ('git push')..."

