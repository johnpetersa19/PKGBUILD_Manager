# CLI strings
msgid "Failed to resolve parent directory"
msgstr "Error al resolver el directorio padre"

msgid "Directory does not exist"
msgstr "El directorio no existe"

msgid "No PKGBUILD found in directory"
msgstr "No se encontró PKGBUILD en el directorio"

msgid "Failed to read PKGBUILD info with makepkg --printsrcinfo"
msgstr "Error al leer la información del PKGBUILD con makepkg --printsrcinfo"

msgid "aur-push-tag requires a version tag argument"
msgstr "aur-push-tag requiere un argumento de etiqueta de versión"

msgid "Unknown command"
msgstr "Comando desconocido"

msgid "PKGBUILD Manager - CLI Tool"
msgstr "PKGBUILD Manager - Herramienta CLI"

msgid "Usage:"
msgstr "Uso:"

msgid "Build commands"
msgstr "Comandos de compilación"

msgid "Compile package (makepkg)"
msgstr "Compilar paquete (makepkg)"

msgid "Compile and clean srcdir (makepkg -c)"
msgstr "Compilar y limpiar el srcdir (makepkg -c)"

msgid "Force recompile (makepkg -f)"
msgstr "Forzar recompilación (makepkg -f)"

msgid "Skip check() function (makepkg --nocheck)"
msgstr "Omitir la función check() (makepkg --nocheck)"

msgid "Skip PGP signature check (makepkg --skippgpcheck)"
msgstr "Omitir la verificación de firma PGP (makepkg --skippgpcheck)"

msgid "Compile with custom flags passed after path"
msgstr "Compilar con flags personalizadas después de la ruta"

msgid "Download and extract sources only (makepkg -o)"
msgstr "Solo descargar y extraer fuentes (makepkg -o)"

msgid "Install commands"
msgstr "Comandos de instalación"

msgid "Compile, install and resolve deps (makepkg -si)"
msgstr "Compilar, instalar y resolver dependencias (makepkg -si)"

msgid "Compile, install and clean srcdir (makepkg -sic)"
msgstr "Compilar, instalar y limpiar el srcdir (makepkg -sic)"

msgid "Force compile and install (makepkg -sif)"
msgstr "Forzar compilación e instalación (makepkg -sif)"

msgid "Install and remove makedeps after (makepkg -sir)"
msgstr "Instalar y eliminar dependencias de compilación después (makepkg -sir)"

msgid "Install without running check()"
msgstr "Instalar sin ejecutar la función check()"

msgid "Install skipping PGP checks"
msgstr "Instalar omitiendo las verificaciones PGP"

msgid "Install with custom flags passed after path"
msgstr "Instalar con flags personalizadas después de la ruta"

msgid "Package metadata commands"
msgstr "Comandos de metadatos del paquete"

msgid "Update checksums in PKGBUILD (updpkgsums)"
msgstr "Actualizar sumas de verificación en PKGBUILD (updpkgsums)"

msgid "Generate checksums and print to stdout (makepkg -g)"
msgstr "Generar sumas de verificación e imprimir (makepkg -g)"

msgid "Regenerate .SRCINFO (makepkg --printsrcinfo)"
msgstr "Regenerar .SRCINFO (makepkg --printsrcinfo)"

msgid "Audit commands"
msgstr "Comandos de auditoría"

msgid "Run namcap on PKGBUILD and built packages"
msgstr "Ejecutar namcap en PKGBUILD y paquetes compilados"

msgid "Run shellcheck on PKGBUILD"
msgstr "Ejecutar shellcheck en PKGBUILD"

msgid "Clean commands"
msgstr "Comandos de limpieza"

msgid "Clean srcdir with makepkg (makepkg -c)"
msgstr "Limpiar el srcdir con makepkg (makepkg -c)"

msgid "Remove src/, pkg/ and built packages"
msgstr "Eliminar src/, pkg/ y paquetes compilados"

msgid "AUR/Git commands"
msgstr "Comandos de AUR/Git"

msgid "Stage, commit and push to AUR (auto message if not provided)"
msgstr "Preparar, confirmar y enviar al AUR (mensaje automático si no se proporciona)"

msgid "Push with version tag (e.g. 1.2.3-1)"
msgstr "Enviar con etiqueta de versión (p.ej. 1.2.3-1)"

msgid "Other"
msgstr "Otros"

msgid "Show this help message"
msgstr "Mostrar este mensaje de ayuda"

msgid "namcap not found. Install it with: sudo pacman -S namcap"
msgstr "namcap no encontrado. Instálelo con: sudo pacman -S namcap"

msgid "namcap failed with status"
msgstr "namcap falló con estado"

msgid "shellcheck not found. Install it with: sudo pacman -S shellcheck"
msgstr "shellcheck no encontrado. Instálelo con: sudo pacman -S shellcheck"

msgid "updpkgsums not found. Install it with: sudo pacman -S pacman-contrib"
msgstr "updpkgsums no encontrado. Instálelo con: sudo pacman -S pacman-contrib"

msgid "makepkg -g failed:"
msgstr "makepkg -g falló:"

