# CLI strings
msgid "Failed to resolve parent directory"
msgstr "Falha ao resolver o diretório pai"

msgid "Directory does not exist"
msgstr "O diretório não existe"

msgid "No PKGBUILD found in directory"
msgstr "Nenhum PKGBUILD encontrado no diretório"

msgid "Failed to read PKGBUILD info with makepkg --printsrcinfo"
msgstr "Falha ao ler informações do PKGBUILD com makepkg --printsrcinfo"

msgid "aur-push-tag requires a version tag argument"
msgstr "aur-push-tag requer um argumento de tag de versão"

msgid "Unknown command"
msgstr "Comando desconhecido"

msgid "PKGBUILD Manager - CLI Tool"
msgstr "Gerenciador de PKGBUILD - Ferramenta CLI"

msgid "Usage:"
msgstr "Uso:"

msgid "Build commands"
msgstr "Comandos de compilação"

msgid "Compile package (makepkg)"
msgstr "Compilar pacote (makepkg)"

msgid "Compile and clean srcdir (makepkg -c)"
msgstr "Compilar e limpar o srcdir (makepkg -c)"

msgid "Force recompile (makepkg -f)"
msgstr "Forçar recompilação (makepkg -f)"

msgid "Skip check() function (makepkg --nocheck)"
msgstr "Pular função check() (makepkg --nocheck)"

msgid "Skip PGP signature check (makepkg --skippgpcheck)"
msgstr "Pular verificação de assinatura PGP (makepkg --skippgpcheck)"

msgid "Compile with custom flags passed after path"
msgstr "Compilar com flags personalizadas passadas após o caminho"

msgid "Download and extract sources only (makepkg -o)"
msgstr "Apenas baixar e extrair fontes (makepkg -o)"

msgid "Install commands"
msgstr "Comandos de instalação"

msgid "Compile, install and resolve deps (makepkg -si)"
msgstr "Compilar, instalar e resolver dependências (makepkg -si)"

msgid "Compile, install and clean srcdir (makepkg -sic)"
msgstr "Compilar, instalar e limpar o srcdir (makepkg -sic)"

msgid "Force compile and install (makepkg -sif)"
msgstr "Forçar compilação e instalação (makepkg -sif)"

msgid "Install and remove makedeps after (makepkg -sir)"
msgstr "Instalar e remover dependências de compilação depois (makepkg -sir)"

msgid "Install without running check()"
msgstr "Instalar sem rodar a função check()"

msgid "Install skipping PGP checks"
msgstr "Instalar pulando verificações PGP"

msgid "Install with custom flags passed after path"
msgstr "Instalar com flags personalizadas passadas após o caminho"

msgid "Package metadata commands"
msgstr "Comandos de metadados do pacote"

msgid "Update checksums in PKGBUILD (updpkgsums)"
msgstr "Atualizar checksums no PKGBUILD (updpkgsums)"

msgid "Generate checksums and print to stdout (makepkg -g)"
msgstr "Gerar checksums e imprimir no stdout (makepkg -g)"

msgid "Regenerate .SRCINFO (makepkg --printsrcinfo)"
msgstr "Regerar .SRCINFO (makepkg --printsrcinfo)"

msgid "Audit commands"
msgstr "Comandos de auditoria"

msgid "Run namcap on PKGBUILD and built packages"
msgstr "Executar namcap no PKGBUILD e nos pacotes compilados"

msgid "Run shellcheck on PKGBUILD"
msgstr "Executar shellcheck no PKGBUILD"

msgid "Clean commands"
msgstr "Comandos de limpeza"

msgid "Clean srcdir with makepkg (makepkg -c)"
msgstr "Limpar o srcdir com makepkg (makepkg -c)"

msgid "Remove src/, pkg/ and built packages"
msgstr "Remover src/, pkg/ e pacotes compilados"

msgid "AUR/Git commands"
msgstr "Comandos do AUR/Git"

msgid "Stage, commit and push to AUR (auto message if not provided)"
msgstr "Adicionar ao stage, fazer commit e push para o AUR (mensagem automática se não informada)"

msgid "Push with version tag (e.g. 1.2.3-1)"
msgstr "Fazer push com tag de versão (ex: 1.2.3-1)"

msgid "Other"
msgstr "Outros"

msgid "Show this help message"
msgstr "Mostrar esta mensagem de ajuda"

msgid "namcap not found. Install it with: sudo pacman -S namcap"
msgstr "namcap não encontrado. Instale com: sudo pacman -S namcap"

msgid "namcap failed with status"
msgstr "namcap falhou com status"

msgid "shellcheck not found. Install it with: sudo pacman -S shellcheck"
msgstr "shellcheck não encontrado. Instale com: sudo pacman -S shellcheck"

msgid "updpkgsums not found. Install it with: sudo pacman -S pacman-contrib"
msgstr "updpkgsums não encontrado. Instale com: sudo pacman -S pacman-contrib"

msgid "makepkg -g failed:"
msgstr "makepkg -g falhou:"

msgid "Removing src/ pkg/ and built packages in"
msgstr "Removendo src/, pkg/ e pacotes compilados em"

msgid "Removed"
msgstr "Removido"

msgid "Note: nothing to commit or commit failed — continuing with push."
msgstr "Nota: nada para commitar ou o commit falhou — continuando com o push."

msgid "makepkg --printsrcinfo failed:"
msgstr "makepkg --printsrcinfo falhou:"

msgid "Note: push to origin/master failed"
msgstr "Nota: push para origin/master falhou"

msgid "Trying plain 'git push'..."
msgstr "Tentando push simples ('git push')..."

