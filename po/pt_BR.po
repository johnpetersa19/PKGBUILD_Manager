msgstr "✔ Sintaxe do PKGBUILD OK"

msgid "PKGBUILD has syntax errors"
msgstr "O PKGBUILD contém erros de sintaxe"

msgid "Parsing PKGBUILD variables (makepkg --nobuild --noextract)…"
msgstr "Analisando variáveis do PKGBUILD (makepkg --nobuild --noextract)…"

msgid "Verifying source checksums (makepkg --verifysource)…"
msgstr "Verificando checksums das fontes (makepkg --verifysource)…"

msgid "Checking declared dependencies (makepkg --syncdeps --nobuild)…"
msgstr "Verificando dependências declaradas (makepkg --syncdeps --nobuild)…"

msgid "validate-offline: PKGBUILD full offline check"
msgstr "validate-offline: verificação completa offline do PKGBUILD"

msgid "All offline checks passed."
msgstr "Todas as verificações offline passaram."

msgid "check(s) failed"
msgstr "verificação(ões) falhou(aram)"

msgid "validate check(s) failed"
msgstr "verificação(ões) de validação falhou(aram)"

msgid "Full offline check: syntax + parse + namcap + shellcheck"
msgstr "Verificação offline completa: sintaxe + parse + namcap + shellcheck"

msgid "Validate syntax only (makepkg --printsrcinfo)"
msgstr "Validar apenas a sintaxe (makepkg --printsrcinfo)"

msgid "Parse variables/functions without extracting (makepkg --nobuild --noextract)"
msgstr "Analisar variáveis/funções sem extrair (makepkg --nobuild --noextract)"

msgid "Download sources and verify checksums (makepkg --verifysource)"
msgstr "Baixar fontes e verificar checksums (makepkg --verifysource)"

msgid "Check declared dependencies exist in repos (makepkg --syncdeps --nobuild)"
msgstr "Verificar se as dependências declaradas existem nos repositórios (makepkg --syncdeps --nobuild)"
