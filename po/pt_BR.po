msgid "Run namcap on PKGBUILD and compiled packages"
msgstr "Executar namcap no PKGBUILD e pacotes compilados"

#: src/main.rs:248
msgid "Run ShellCheck on PKGBUILD"
msgstr "Executar ShellCheck no PKGBUILD"

#: src/main.rs:251
msgid "Clean srcdir with makepkg (makepkg -c)"
msgstr "Limpar srcdir com makepkg (makepkg -c)"

#: src/main.rs:252
msgid "Remove src/, packages/ and compiled packages"
msgstr "Remover src/, pkg/ e pacotes compilados"

#: src/main.rs:255
msgid "Stage, commit and push to the AUR (automatic message if not provided)"
msgstr "Stage, commit e push para o AUR (mensagem automática se não fornecida)"

#: src/main.rs:256
msgid "Push with version tag (e.g., 1.2.3-1)"
msgstr "Push com tag de versão (ex: 1.2.3-1)"

#: src/main.rs:259
msgid "Remove obsolete symbolic links and check the Nautilus extension"
msgstr "Remover links simbólicos obsoletos e verificar a extensão do Nautilus"

