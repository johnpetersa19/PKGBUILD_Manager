msgid "Install without running check()"
msgstr "Instalar sem executar check()"

#: src/main.rs:237
msgid "Install skipping PGP checks"
msgstr "Instalar pulando verificações PGP"

#: src/main.rs:238
msgid "Install with custom flags after the path"
msgstr "Instalar com flags personalizadas após o caminho"

