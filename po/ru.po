# CLI strings
msgid "Failed to resolve parent directory"
msgstr "Не удалось определить родительский каталог"

msgid "Directory does not exist"
msgstr "Каталог не существует"

msgid "No PKGBUILD found in directory"
msgstr "PKGBUILD не найден в каталоге"

msgid "Failed to read PKGBUILD info with makepkg --printsrcinfo"
msgstr "Не удалось прочитать информацию PKGBUILD с помощью makepkg --printsrcinfo"

msgid "aur-push-tag requires a version tag argument"
msgstr "aur-push-tag требует аргумент тега версии"

msgid "Unknown command"
msgstr "Неизвестная команда"

msgid "PKGBUILD Manager - CLI Tool"
msgstr "PKGBUILD Manager - Инструмент командной строки"

msgid "Usage:"
msgstr "Использование:"

msgid "Build commands"
msgstr "Команды сборки"

msgid "Compile package (makepkg)"
msgstr "Собрать пакет (makepkg)"

msgid "Compile and clean srcdir (makepkg -c)"
msgstr "Собрать и очистить каталог источников (makepkg -c)"

msgid "Force recompile (makepkg -f)"
msgstr "Принудительная пересборка (makepkg -f)"

msgid "Skip check() function (makepkg --nocheck)"
msgstr "Пропустить функцию check() (makepkg --nocheck)"

msgid "Skip PGP signature check (makepkg --skippgpcheck)"
msgstr "Пропустить проверку подписи PGP (makepkg --skippgpcheck)"

msgid "Compile with custom flags passed after path"
msgstr "Собрать с пользовательскими флагами после пути"

msgid "Download and extract sources only (makepkg -o)"
msgstr "Только загрузить и извлечь исходники (makepkg -o)"

msgid "Install commands"
msgstr "Команды установки"

msgid "Compile, install and resolve deps (makepkg -si)"
msgstr "Собрать, установить и разрешить зависимости (makepkg -si)"

msgid "Compile, install and clean srcdir (makepkg -sic)"
msgstr "Собрать, установить и очистить каталог источников (makepkg -sic)"

msgid "Force compile and install (makepkg -sif)"
msgstr "Принудительно собрать и установить (makepkg -sif)"

msgid "Install and remove makedeps after (makepkg -sir)"
msgstr "Установить и удалить зависимости сборки (makepkg -sir)"

msgid "Install without running check()"
msgstr "Установить без запуска check()"

msgid "Install skipping PGP checks"
msgstr "Установить, пропустив проверки PGP"

msgid "Install with custom flags passed after path"
msgstr "Установить с пользовательскими флагами после пути"

msgid "Package metadata commands"
msgstr "Команды метаданных пакета"

msgid "Update checksums in PKGBUILD (updpkgsums)"
msgstr "Обновить контрольные суммы в PKGBUILD (updpkgsums)"

msgid "Generate checksums and print to stdout (makepkg -g)"
msgstr "Создать контрольные суммы и вывести на экран (makepkg -g)"

msgid "Regenerate .SRCINFO (makepkg --printsrcinfo)"
msgstr "Пересоздать .SRCINFO (makepkg --printsrcinfo)"

msgid "Audit commands"
msgstr "Команды аудита"

msgid "Run namcap on PKGBUILD and built packages"
msgstr "Запустить namcap для PKGBUILD и собранных пакетов"

msgid "Run shellcheck on PKGBUILD"
msgstr "Запустить shellcheck для PKGBUILD"

msgid "Clean commands"
msgstr "Команды очистки"

msgid "Clean srcdir with makepkg (makepkg -c)"
msgstr "Очистить каталог источников с помощью makepkg (makepkg -c)"

msgid "Remove src/, pkg/ and built packages"
msgstr "Удалить src/, pkg/ и собранные пакеты"

msgid "AUR/Git commands"
msgstr "Команды AUR/Git"

msgid "Stage, commit and push to AUR (auto message if not provided)"
msgstr "Подготовить, зафиксировать и отправить в AUR (авто-сообщение, если не задано)"

msgid "Push with version tag (e.g. 1.2.3-1)"
msgstr "Отправить с тегом версии (например 1.2.3-1)"

msgid "Other"
msgstr "Прочее"

msgid "Show this help message"
msgstr "Показать это справочное сообщение"

msgid "namcap not found. Install it with: sudo pacman -S namcap"
msgstr "namcap не найден. Установите: sudo pacman -S namcap"

msgid "namcap failed with status"
msgstr "namcap завершился со статусом"

msgid "shellcheck not found. Install it with: sudo pacman -S shellcheck"
msgstr "shellcheck не найден. Установите: sudo pacman -S shellcheck"

msgid "updpkgsums not found. Install it with: sudo pacman -S pacman-contrib"
msgstr "updpkgsums не найден. Установите: sudo pacman -S pacman-contrib"

msgid "makepkg -g failed:"
msgstr "makepkg -g завершился с ошибкой:"

msgid "Removing src/ pkg/ and built packages in"
msgstr "Удаление src/, pkg/ и собранных пакетов в"

msgid "Removed"
msgstr "Удалено"

msgid "Note: nothing to commit or commit failed — continuing with push."
msgstr "Примечание: нечего фиксировать или фиксация завершилась с ошибкой — продолжение отправки."

msgid "makepkg --printsrcinfo failed:"
msgstr "makepkg --printsrcinfo завершился с ошибкой:"

msgid "Note: push to origin/master failed"
msgstr "Примечание: отправка в origin/master завершилась с ошибкой"

msgid "Trying plain 'git push'..."
msgstr "Попытка обычного 'git push'..."

msgid "Symlink scripts to user directory with localization"
msgstr "Создать символические ссылки на скрипты в каталоге пользователя с локализацией"

msgid "Nautilus scripts successfully configured under 'PKGBUILD' submenu."
msgstr "Скрипты Nautilus успешно настроены в подменю 'PKGBUILD'."
