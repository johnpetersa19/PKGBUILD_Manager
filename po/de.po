msgid "Failed to resolve parent directory"
msgstr "Übergeordnetes Verzeichnis konnte nicht aufgelöst werden"

msgid "Directory does not exist"
msgstr "Verzeichnis existiert nicht"

msgid "No PKGBUILD found in directory"
msgstr "Keine PKGBUILD im Verzeichnis gefunden"

msgid "Failed to read PKGBUILD info with makepkg --printsrcinfo"
msgstr "PKGBUILD-Informationen konnten nicht mit makepkg --printsrcinfo gelesen werden"

msgid "aur-push-tag requires a version tag argument"
msgstr "aur-push-tag erfordert ein Versions-Tag-Argument"

msgid "Unknown command"
msgstr "Unbekannter Befehl"

msgid "PKGBUILD Manager - CLI Tool"
msgstr "PKGBUILD-Manager - CLI-Tool"

msgid "Usage:"
msgstr "Verwendung:"

msgid "Build commands"
msgstr "Build-Befehle"

msgid "Compile package (makepkg)"
msgstr "Paket kompilieren (makepkg)"

msgid "Compile and clean srcdir (makepkg -c)"
msgstr "Kompilieren und srcdir bereinigen (makepkg -c)"

msgid "Force recompile (makepkg -f)"
msgstr "Recompilierung erzwingen (makepkg -f)"

msgid "Skip check() function (makepkg --nocheck)"
msgstr "check()-Funktion überspringen (makepkg --nocheck)"

msgid "Skip PGP signature check (makepkg --skippgpcheck)"
msgstr "PGP-Signaturprüfung überspringen (makepkg --skippgpcheck)"

msgid "Compile with custom flags passed after path"
msgstr "Kompilieren mit benutzerdefinierten Flags nach dem Pfad"

msgid "Download and extract sources only (makepkg -o)"
msgstr "Nur Quellen herunterladen und entpacken (makepkg -o)"

msgid "Install commands"
msgstr "Installationsbefehle"

msgid "Compile, install and resolve deps (makepkg -si)"
msgstr "Kompilieren, installieren und Abhängigkeiten auflösen (makepkg -si)"

msgid "Compile, install and clean srcdir (makepkg -sic)"
msgstr "Kompilieren, installieren und srcdir bereinigen (makepkg -sic)"

msgid "Force compile and install (makepkg -sif)"
msgstr "Kompilierung und Installation erzwingen (makepkg -sif)"

msgid "Install and remove makedeps after (makepkg -sir)"
msgstr "Installieren und makedeps danach entfernen (makepkg -sir)"

msgid "Install without running check()"
msgstr "Installieren ohne check() auszuführen"

msgid "Install skipping PGP checks"
msgstr "Installieren ohne PGP-Prüfungen"

msgid "Install with custom flags passed after path"
msgstr "Installieren mit benutzerdefinierten Flags nach dem Pfad"

msgid "Package metadata commands"
msgstr "Paket-Metadatenbefehle"

msgid "Update checksums in PKGBUILD (updpkgsums)"
msgstr "Prüfsummen in PKGBUILD aktualisieren (updpkgsums)"

msgid "Generate checksums and print to stdout (makepkg -g)"
msgstr "Prüfsummen generieren und auf stdout ausgeben (makepkg -g)"

msgid "Regenerate .SRCINFO (makepkg --printsrcinfo)"
msgstr ".SRCINFO neu generieren (makepkg --printsrcinfo)"

msgid "Audit commands"
msgstr "Audit-Befehle"

msgid "Run namcap on PKGBUILD and built packages"
msgstr "Namcap für PKGBUILD und erstellte Pakete ausführen"

msgid "Run shellcheck on PKGBUILD"
msgstr "Shellcheck für PKGBUILD ausführen"

msgid "Clean commands"
msgstr "Bereinigungsbefehle"

msgid "Clean srcdir with makepkg (makepkg -c)"
msgstr "srcdir mit makepkg bereinigen (makepkg -c)"

msgid "Remove src/, pkg/ and built packages"
msgstr "src/, pkg/ und erstellte Pakete entfernen"

msgid "AUR/Git commands"
msgstr "AUR/Git-Befehle"

msgid "Stage, commit and push to AUR (auto message if not provided)"
msgstr "Stagen, committen und an AUR pushen (automatische Nachricht, falls nicht angegeben)"

msgid "Push with version tag (e.g. 1.2.3-1)"
msgstr "Mit Versions-Tag pushen (z. B. 1.2.3-1)"

msgid "Other"
msgstr "Sonstiges"

msgid "Show this help message"
msgstr "Diese Hilfemeldung anzeigen"

msgid "namcap not found. Install it with: sudo pacman -S namcap"
msgstr "namcap nicht gefunden. Installieren Sie es mit: sudo pacman -S namcap"

msgid "namcap failed with status"
msgstr "namcap fehlgeschlagen mit Status"

msgid "shellcheck not found. Install it with: sudo pacman -S shellcheck"
msgstr "shellcheck nicht gefunden. Installieren Sie es mit: sudo pacman -S shellcheck"

msgid "updpkgsums not found. Install it with: sudo pacman -S pacman-contrib"
msgstr "updpkgsums nicht gefunden. Installieren Sie es mit: sudo pacman -S pacman-contrib"

msgid "makepkg -g failed:"
msgstr "makepkg -g fehlgeschlagen:"

msgid "Removing src/ pkg/ and built packages in"
msgstr "Entferne src/, pkg/ und erstellte Pakete in"

msgid "Removed"
msgstr "Entfernt"

msgid "Note: nothing to commit or commit failed — continuing with push."
msgstr "Hinweis: Nichts zu committen oder Commit fehlgeschlagen — fahre mit Push fort."

msgid "makepkg --printsrcinfo failed:"
msgstr "makepkg --printsrcinfo fehlgeschlagen:"

msgid "Note: push to origin/master failed"
msgstr "Hinweis: Push an origin/master fehlgeschlagen"

msgid "Trying plain 'git push'..."
msgstr "Versuche einfachen 'git push'..."
