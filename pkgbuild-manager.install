post_install() {
  echo ">>> To enable and localize the Nautilus context menu scripts for your user, run:"
  echo ">>>   pkgbuild_manager setup-nautilus"
  echo ">>> Restarting Nautilus to apply changes..."
  pkill -u "${SUDO_USER:-$USER}" nautilus 2>/dev/null || true
}

post_upgrade() {
  post_install
}
