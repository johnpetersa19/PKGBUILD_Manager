#!/bin/bash
# PKGBUILD Manager - Clean srcdir (makepkg -c)
TARGET="${1:-.}"
notify-send "PKGBUILD Manager" "Cleaning srcdir..."

if pkgbuild_manager clean "$TARGET"; then
    notify-send "PKGBUILD Manager" "✓ srcdir cleaned successfully!"
else
    notify-send -u critical "PKGBUILD Manager" "✗ Failed to clean srcdir."
fi
