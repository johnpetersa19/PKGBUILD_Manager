#!/bin/bash
# PKGBUILD Manager - Update checksums (updpkgsums)
TARGET="${1:-.}"
notify-send "PKGBUILD Manager" "Updating checksums..."

if pkgbuild_manager checksums "$TARGET"; then
    notify-send "PKGBUILD Manager" "✓ Checksums updated successfully!"
else
    notify-send -u critical "PKGBUILD Manager" "✗ Failed to update checksums."
fi
